library(sva)

pheno_all <- pData(norm_data)
expr_all <- expr_matrix

# Protect the phenotype (Controls vs TH2-High vs TH2-Low)
# We use 'th2_group' where NAs (controls) are labeled as "Control"
pheno_all$th2_group[is.na(pheno_all$th2_group)] <- "Control"

mod  <- model.matrix(~ as.factor(th2_group), data = pheno_all)
mod0 <- model.matrix(~ 1, data = pheno_all)

# Find SVs across the whole dataset
n.sv <- num.sv(expr_all, mod, method = "be")

expr_all <- as.matrix(expr_all)

svobj <- sva(expr_all, mod, mod0, n.sv = n.sv)

# Clean the ENTIRE matrix
expr_corrected <- removeBatchEffect(expr_all, covariates = svobj$sv)

pca_clean <- prcomp(t(expr_corrected), scale. = TRUE)
summary(pca_clean)

# PCA CORRECTED

pca2 <- prcomp(t(expr_corrected))
eigen2 <- get_eigenvalue(pca2)

pca_plot <- function(i, u) {
  df2 <- data.frame(
    PCi = pca2$x[, i],
    PCu = pca2$x[, u],
    th2 = pData(norm_data)$th2_group
  )
  
  p <- ggplot(df2, aes(PCi, PCu, color = th2)) +
    geom_point(size = 3)  +
    labs(x = paste0("PC", i, " (", round(eigen2[i, 2], 2), "%)"),
         y = paste0("PC", u, " (", round(eigen2[u, 2], 2), "%)"))
  print(p)
}

pca_plot(i = 1, u = 2)




# Get mapping to change probe IDs to gene names

probe_gene <- AnnotationDbi::select(
  hgu133plus2.db,
  keys = rownames(expr_corrected),
  columns = "SYMBOL",
  keytype = "PROBEID"
)

# Eliminate NAs in symbol column  

probe_gene <- probe_gene[!is.na(probe_gene$SYMBOL), ]

# Same for duplicated data

probe_gene <- probe_gene[!duplicated(probe_gene), ]

# Make data frame

expr_df <- as.data.frame(expr_corrected)

# Asign the row names as the probe IDs for later merge

expr_df$PROBEID <- rownames(expr_df)

# Join the object that has the counts and the object with the gene names 

expr_annot <- left_join(expr_df, probe_gene, by = "PROBEID")

# Group the symbol duplicates and assign the mean of the counts

expr_gene <- expr_annot %>%
  group_by(SYMBOL) %>%
  summarise(across(where(is.numeric), mean))

# Eliminate NAs in symbol

expr_gene <- expr_gene[!is.na(expr_gene$SYMBOL), ]

# Data frame

expr_gene_mat <- as.data.frame(expr_gene)

# Assign the symbol ids to rownames

rownames(expr_gene_mat) <- expr_gene_mat$SYMBOL

# Delete the symbol column

expr_gene_mat$SYMBOL <- NULL

# To eliminate controls, it selects all controls since in the original data
# only the controls had NA in th2 phenotype

keep <- !is.na(pData(norm_data)$th2_group)

# Object with only asthma patients and corrected by batch effect

expr_asthma <- expr_gene_mat[, keep]

pheno_asthma <- pData(norm_data)[keep, ]

all(colnames(expr_gene_mat)[keep] == pheno_asthma$file_name)



