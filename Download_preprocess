# Listing .cel files

cel_files <- list.celfiles("Data/GSE67472/", full.names = TRUE, listGzipped = TRUE)

# Reading in cel files

raw_data <- read.celfiles(cel_files)

# Object with the names of each file

file_name <- sampleNames(raw_data)


# Metadata

gse <- getGEO("GSE67472", destdir = "C:/R/TH2_LOW/Metadata", getGPL = FALSE)

# Extract metadata (pData)

metadata <- pData(phenoData(gse[[1]]))

metadata_th <- metadata %>% 
  dplyr::select(geo_accession, `th2 group:ch1`)

# View the first few rows
head(metadata)

# Add the object to the phenotipic data

pData(raw_data)$file_name <- file_name

# Names that correspond to the metadata

sample_names <- gsub("_.*", "", file_name)

# Make sure names are the same as in phenotipic data

sampleNames(raw_data) <- file_name

# Add the names to de phenotipic data

pData(raw_data)$geo_accession <- sample_names

# Add if TH2 high or low to phenotipic data

idx <- match(pData(raw_data)$geo_accession, metadata_th$geo_accession)

pData(raw_data)$th2_group <- metadata_th$`th2 group:ch1`[idx]


# Boxplot of raw data

boxplot(raw_data)

# Data normalization

norm_data <- rma(raw_data)

# Boxplot of normalized data

boxplot(norm_data)


# Expressión matrix

expr_matrix <- exprs(norm_data)


# We can observe that there is a batch effect since there are 2 extremely separated groups by
# PC 1 with few sense since it mixes TH2 high, TH2 low and healthy subjects

# Transpose expression matrix and make pca object

pca <- prcomp(t(expr_matrix))

# Convert to data frame of only PC 1 and PC 2

df <- data.frame(
  PC1 = pca$x[,1],
  PC2 = pca$x[,2],
  th2 = pData(norm_data)$th2_group
)

# Plot PCA

ggplot(df, aes(PC1, PC2, color = th2)) +
  geom_point(size = 3)


