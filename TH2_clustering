library(ConsensusClusterPlus)

expr_clean <- expr_th2_low

var_genes <- apply(expr_clean, 1, var)

top_genes <- names(sort(var_genes, decreasing = TRUE))[1:3000]

cluster_counts <- expr_clean[top_genes, ]

# Convert to matrix

count_matrix <- as.matrix(cluster_counts)


# Clustering ----------------------------------------------------------



results <- ConsensusClusterPlus(
  count_matrix, # Objetoa procesar, debe ser una matriz
  maxK = 6, # Numero maximo de clusters
  reps = 1000, # Cuantas veces se repetira la funcipon
  pItem = 0.8, # Cuantos items (1 = 100%)
  pFeature = 1, # Cuantos features (1 = 100%) 
  title = "Results/Cluster/", # A donde se van a guardar las imagenes
  clusterAlg = "hc", # Cluster jerarquico
  distance = "pearson",
  seed = 1262118388.71279,
  plot = "png"
)


# Observe object

results

# Integretad classification likelyhood

icl = calcICL(results, title = "Results/Cluster/", plot = "png")
icl$clusterConsensus

# Convert to data frame to aggregate

icl_df <- as.data.frame(icl$clusterConsensus)

# Observe the highest mean for k in icl

aggregate(data = icl_df, clusterConsensus ~ k, FUN = mean)


# Convert the results cluster object corresponding to selected k to a data frame

cluster_by_sample <- as.data.frame(results[[2]]$consensusClass)

# Next 2 lines are to create the column with the name that we desire and eliminate the other

cluster_by_sample$cluster <- cluster_by_sample$`results[[2]]$consensusClass`

cluster_by_sample$`results[[2]]$consensusClass` <- NULL


# Make a column with the rownames (the patient IDs) called the same as the 
# corresponding column in the metadata

cluster_by_sample$file_name <- rownames(cluster_by_sample)

# Such as that both data can be joined and thus in the metadata there is a column
# that specifiec to which cluster do each patient belong to

th2_low <- left_join(x = th2_low, y = cluster_by_sample, by = "file_name")

rownames(th2_low) <- th2_low$file_name

# PCA of expression

pca_th2_low <- PCA(t(expr_th2_low))

# PCA plot dividing by the clusters previously established

fviz_pca_ind(pca_th2_low,
             habillage = th2_low$cluster,
             geom = "point",
)

# Observe the distribution of the original publications TH2 classification
# within our clusters

th2_low %>% 
  filter(.preserve = c(th2_group, cluster)) %>% 
  count(th2_group, cluster)

